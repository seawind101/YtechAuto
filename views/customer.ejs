<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Customer - Auto Repair Ticket System</title>
  <link rel="stylesheet" href="css/styles.css">
</head>
<body>
  <header class="site-header">
    <a href="/">Auto Repair Ticket System</a>
    <p class="tagline">Customer View - Your Repair Ticket</p>
  </header>

  <main class="main-content">
    <a href="/" class="back-link">&larr; Back to Home</a>
    <a href="/customerDis" class="btn btn-secondary" style="margin-left:1rem">View All</a>
    <!-- Ticket Summary -->
    <section class="section">
      <h2 id="ticketNum">Repair Ticket (Number here)</h2>
      <div class="form-grid">
        <div class="read-only-value">
          <div class="read-only-label">Date</div>
          <div id="dateOut"></div>
        </div>
        <div class="read-only-value">
          <div class="read-only-label">Technician</div>
          <div id="technicianOut"></div>
        </div>
        <div class="read-only-value">
          <div class="read-only-label">Vehicle</div>
          <div id="MMYOut"></div>
        </div>
        <div class="read-only-value">
          <div class="read-only-label">License Plate</div>
          <div id="licensePlateOut"></div>
        </div>
        <div class="read-only-value">
          <div class="read-only-label">Mileage In / Out</div>
          <div id="mileageIn-Out"></div>
        </div>
      </div>
    </section>

    <!-- Mechanic Notes - Concern -->
    <section class="section">
      <h2>Your Concern</h2>
      <p id="concernOut"></p>
    </section>

    <!-- Mechanic Notes - Diagnosis -->
    <section class="section">
      <h2>Diagnosis / Cause / Correction</h2>
      <p id="diagnosisOut"></p>
    </section>

    <!-- Recommended Repairs (completed work shown) -->
    <section class="section">
      <h2>Work Performed</h2>
      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>Description of Work</th>
              <th>Qty</th>
              <th>Parts #</th>
              <th>Parts Total $</th>
              <th>Labor Total $</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td id="descOfWork1"></td>
              <td id="qty1"></td>
              <td id="partsNum1"></td>
              <td id="partTot1"></td>
              <td id="LabourTot1"></td>
            </tr>
            <tr>
              <td id="descOfWork2"></td>
              <td id="qty2"></td>
              <td id="partsNum2"></td>
              <td id="partTot2"></td>
              <td id="LabourTot2"></td>
            </tr>
            <tr>
              <td id="descOfWork3"></td>
              <td id="qty3"></td>
              <td id="partsNum3"></td>
              <td id="partTot3"></td>
              <td id="LabourTot3"></td>
            </tr>
            <tr>
              <td id="descOfWork4"></td>
              <td id="qty4"></td>
              <td id="partsNum4"></td>
              <td id="partTot4"></td>
              <td id="LabourTot4"></td>
            </tr>
          </tbody>
        </table>
      </div>
      <div class="form-grid" style="margin-top:1rem; max-width:400px">
        <div class="read-only-value">
          <div class="read-only-label">Subtotal (Parts)</div>
          <div id="subTotParts"></div>
        </div>
        <div class="read-only-value">
          <div class="read-only-label">Subtotal (Labor)</div>
          <div id="subTotLabor"></div>
        </div>
        <div class="read-only-value">
          <div class="read-only-label">Tax</div>
          <div id="tax"></div>
        </div>
        <div class="read-only-value">
          <div class="read-only-label">Total</div>
          <div id="totalOut"><strong></strong></div>
        </div>
      </div>
    </section>

    <!-- Vehicle Inspection Summary -->
    <section class="section">
      <h2>Vehicle Inspection Summary</h2>
      <p>Warnings from courtesy check:</p>
      <div class="inspection-summary">
        <div class="inspection-item">
          <span class="status-badge status-green">OK</span>
          <span>Model-Green</span>
        </div>
        <div class="inspection-item">
          <span class="status-badge status-yellow">Monitor</span>
          <span>Model-Yellow</span>
        </div>
        <div class="inspection-item">
          <span class="status-badge status-red">Needs Service</span>
          <span>Model-Red</span>
        </div>
      </div>
    </section>

    <!-- Video Section - FUNCTIONAL -->
    <section class="section video-section">
      <h2>Inspection Video</h2>
      <p>Watch the mechanic's video walkthrough of the inspection and repairs.</p>
      <video controls width="640">
        <source src="Recording-20260212_111802.webm" type="video/webm">
        Your browser does not support the video tag.
      </video>
      <div>
        <a href="Recording-20260212_111802.webm" download="inspection-video.webm" class="video-download-link">Download Video</a>
      </div>
    </section>
  </main>
</body>
</html>
