<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Customer Display</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <header class="site-header">
    <h1>Auto Repair Ticket System</h1>
    <p class="tagline">York County School of Technology</p>
  </header>

  <main class="landing">
    <a href="/" class="back-link">&larr; Back to Home</a>
    
    
    <h2>Your Repair Tickets</h2>
    <p>Welcome <strong><%= typeof user !== 'undefined' ? user.email : 'Customer' %></strong>! Here are all your completed repair tickets:</p>

    <% if (typeof tickets !== 'undefined' && tickets.length > 0) { %>
        <% tickets.forEach((ticket, index) => { %>
            <section class="section" style="border: 1px solid #ccc; padding: 1rem; margin-top: 1rem; border-radius: 8px;">
                <h3>Ticket #<%= ticket.id %> 
                    <span class="status-badge status-<%= ticket.stat === 'Complete' ? 'green' : ticket.stat === 'open' ? 'yellow' : 'red' %>">
                        <%= ticket.stat %>
                    </span>
                </h3>
                
                <div class="form-grid">
                    <div class="read-only-value">
                        <div class="read-only-label">Date</div>
                        <div><%= ticket.date %></div>
                    </div>
                    <div class="read-only-value">
                        <div class="read-only-label">Technician</div>
                        <div><%= ticket.techName %></div>
                    </div>
                    <div class="read-only-value">
                        <div class="read-only-label">Time In/Out</div>
                        <div><%= ticket.timeIn %> - <%= ticket.timeOut || 'In Progress' %></div>
                    </div>
                    <div class="read-only-value">
                        <div class="read-only-label">Total Time</div>
                        <div><%= ticket.totalTime %></div>
                    </div>
                </div>
                
                <div style="margin-top: 1rem;">
                    <h4>Your Concern:</h4>
                    <p><%= ticket.concern %></p>
                </div>
                
                <div style="margin-top: 1rem;">
                    <h4>Diagnosis/Correction:</h4>
                    <p><%= ticket.diagnosis %></p>
                </div>
                
                <div style="margin-top: 1rem;">
                    <a href="/customer?ticketId=<%= ticket.id %>" class="btn btn-primary">View Full Details</a>
                </div>
            </section>
        <% }) %>
    <% } else { %>
        <section class="section" style="border: 1px solid #ccc; padding: 1rem; margin-top: 1rem; border-radius: 8px; text-align: center;">
            <h3>No Tickets Found</h3>
            <p>You don't have any repair tickets yet.</p>
            <p>When you bring your vehicle in for service, your tickets will appear here.</p>
        </section>
    <% } %>
  </main>

  <footer class="section" style="text-align:center;">
    <small>Customer view for Auto Repair Ticket System - Showing <%= typeof tickets !== 'undefined' ? tickets.length : 0 %> ticket(s)</small>
  </footer>
</body>
</html>
