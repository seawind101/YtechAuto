<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Auto Repair Ticket System</title>
  <link rel="stylesheet" href="css/styles.css">
</head>
<body>
  <header class="site-header">
    <h1>Auto Repair Ticket System</h1>
    <p class="tagline">York County School of Technology</p>
  </header>

  <main class="landing">
    <h2>Select Your Role</h2>
    <div class="role-cards">
      <a href="/mechanic" class="role-card mechanic-card">
        <span class="role-icon">&#128295;</span>
        <h3>Mechanic</h3>
        <p>Create and edit repair tickets, complete vehicle inspections, upload videos</p>
      </a>
      <a href="/customer" class="role-card customer-card">
        <span class="role-icon">&#128100;</span>
        <h3>Customer</h3>
        <p>View your repair tickets and mechanic notes, watch inspection videos</p>
      </a>
    </div>
  </main>
</body>
</html>
