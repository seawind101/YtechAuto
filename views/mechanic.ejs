                  <tr><td>Battery/Cables</td><td><select><option>Red</option><option>Yellow</option><option>Green</option></select></td><td><input type="text" placeholder="Notes"></td></tr>
                  <tr><td>Accessory Belt</td><td><select><option>Red</option><option>Yellow</option><option>Green</option></select></td><td><input type="text" placeholder="Notes"></td></tr>
                  <tr><td>Washer Fluid</td><td><select><option>Red</option><option>Yellow</option><option>Green</option></select></td><td><input type="text" placeholder="Notes"></td></tr>
                  <tr><td>Engine Oil Level</td><td><select><option>Red</option><option>Yellow</option><option>Green</option></select></td><td><input type="text" placeholder="Notes"></td></tr>
                  <tr><td>Coolant Level</td><td><select><option>Red</option><option>Yellow</option><option>Green</option></select></td><td><input type="text" placeholder="Notes"></td></tr>
                  <tr><td>Brake Fluid</td><td><select><option>Red</option><option>Yellow</option><option>Green</option></select></td><td><input type="text" placeholder="Notes"></td></tr>
                  <tr><td>Spark Plugs</td><td><select><option>Red</option><option>Yellow</option><option>Green</option></select></td><td><input type="text" placeholder="Notes"></td></tr>
                  <tr><td>Oxygen Sensor</td><td><select><option>Red</option><option>Yellow</option><option>Green</option></select></td><td><input type="text" placeholder="Notes"></td></tr>
                  <tr><td>Oil Change Due</td><td><select><option>Red</option><option>Yellow</option><option>Green</option></select></td><td><input type="text" placeholder="Notes"></td></tr>
                  <tr><td>Timing Belt</td><td><select><option>Red</option><option>Yellow</option><option>Green</option></select></td><td><input type="text" placeholder="Notes"></td></tr>
                  <tr><td>Brake Lights</td><td><select><option>Red</option><option>Yellow</option><option>Green</option></select></td><td><input type="text" placeholder="Notes"></td></tr>
                  <tr><td>Turn Signals</td><td><select><option>Red</option><option>Yellow</option><option>Green</option></select></td><td><input type="text" placeholder="Notes"></td></tr>
                  <tr><td>Parking Lights</td><td><select><option>Red</option><option>Yellow</option><option>Green</option></select></td><td><input type="text" placeholder="Notes"></td></tr>
                  </tbody>
              </table>
            </div>

            <div class="form-group full-width"><label>Comments</label><input type="text" placeholder="Comments"></div>

            <button type="button" class="section-save btn btn-secondary" data-section="courtesy-check" style="margin-top:8px">Save</button>
          </div>
        </div>

        <div class="accordion-item">
          <div class="accordion-header" data-accordion="tires">Tires</div>
          <div class="accordion-content collapsed-content" id="tires">
            <div class="form-grid">
              <div class="form-group"><label>Size</label><input type="text" placeholder="Size"></div>
              <div class="form-group"><label>Speed Rating</label><input type="text" placeholder="Speed Rating"></div>
              <div class="form-group"><label>LF</label><input type="text" placeholder="Tread"></div>
              <div class="form-group"><label>RF</label><input type="text" placeholder="Tread"></div>
              <div class="form-group"><label>LR</label><input type="text" placeholder="Tread"></div>
              <div class="form-group"><label>RR</label><input type="text" placeholder="Tread"></div>
              <div class="form-group"><label>SP</label><input type="text" placeholder="Spare"></div>
              <div class="form-group"><label>Tread Depth (32nds)</label><input type="text" placeholder="Depth"></div>
              <div class="form-group"><label>Rotation Due?</label><select><option>Yes</option><option>No</option><option>N/A</option></select></div>
              <div class="form-group"><label>Balance?</label><select><option>Yes</option><option>No</option><option>N/A</option></select></div>
              <div class="form-group"><label>Alignment Check?</label><select><option>Yes</option><option>No</option><option>N/A</option></select></div>
              <div class="form-group full-width"><label>Comments</label><input type="text" placeholder="Tire comments"></div>
            </div>
            <button type="button" class="section-save btn btn-secondary" data-section="tires" style="margin-top:8px">Save</button>
          </div>
        </div>

        <div class="accordion-item">
          <div class="accordion-header" data-accordion="steering">Steering & Suspension / Driveline</div>
