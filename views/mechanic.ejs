                  <tr><td>CV Boots</td><td><select><option>OK</option><option>Monitor</option><option>Replace</option></select></td><td><select><option>OK</option><option>Monitor</option><option>Replace</option></select></td><td><select><option>OK</option><option>Monitor</option><option>Replace</option></select></td><td><select><option>OK</option><option>Monitor</option><option>Replace</option></select></td>
                  <tr><td>CV Joints</td><td><select><option>OK</option><option>Monitor</option><option>Replace</option></select></td><td><select><option>OK</option><option>Monitor</option><option>Replace</option></select></td><td><select><option>OK</option><option>Monitor</option><option>Replace</option></select></td><td><select><option>OK</option><option>Monitor</option><option>Replace</option></select></td>
                  <tr><td>Shocks</td><td><select><option>OK</option><option>Monitor</option><option>Replace</option></select></td><td><select><option>OK</option><option>Monitor</option><option>Replace</option></select></td><td><select><option>OK</option><option>Monitor</option><option>Replace</option></select></td><td><select><option>OK</option><option>Monitor</option><option>Replace</option></select></td>
