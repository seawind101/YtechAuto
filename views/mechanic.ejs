<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mechanic - Auto Repair Ticket System</title>
  <link rel="stylesheet" href="css/styles.css">
  <script src="js/mockup.js"></script>
  <script src="js/form.js"></script>
</head>
<body>
  <header class="site-header">
    <a href="/">Auto Repair Ticket System</a>
    <p class="tagline">Mechanic View - Create & Edit Tickets</p>
  </header>

  <main class="main-content">
    <a href="/" class="back-link">&larr; Back to Home</a>
    <a href="/mechanicDis" class="btn btn-secondary" style="margin-left:1rem">View your page</a>
    

    <!-- Repair Order Section -->
    <section class="section">
      <h2>Repair Order</h2>
      <form class="repair-order-form" id="repForm" method="POST" action="/mechanic">
        <div class="form-grid">
          <div class="form-group">
            <label for="roNum">Repair Order or Task Number #</label>
            <input type="text" name="roNum" id="roNum" placeholder="Enter RO number">
          </div>
          <div class="form-group">
            <label for="roDate">Date</label>
            <input type="date" name="roDate" id="roDate">
          </div>
          <div class="form-group">
            <label for="technician">Technician Name(s)</label>
            <input type="text" name="technician" id="technician" placeholder="Enter technician name">
          </div>
        </div>

       <h3>Time Information</h3>
        <div class="form-grid">
          <div class="form-group">
        <label for="timeIn">Time In</label>
        <div class="time-picker" id="timeInPicker" style="display:flex;gap:6px;align-items:center">
          <select id="timeInHour" class="time-part"></select>
          <select id="timeInMinute" class="time-part"></select>
          <select id="timeInAmPm" class="time-part"></select>
        </div>
        <input type="hidden" id="timeIn" name="timeIn" value="">
         </div>
         <div class="form-group">
          <label for="timeOut">Time Out</label>
        <div class="time-picker" id="timeOutPicker" style="display:flex;gap:6px;align-items:center">
          <select id="timeOutHour" class="time-part"></select>
          <select id="timeOutMinute" class="time-part"></select>
          <select id="timeOutAmPm" class="time-part"></select>
        </div>
        <input type="hidden" id="timeOut" name="timeOut" value="">
       </div>
        <div class="form-group">
        <label for="totTime">Total Time</label>
         <input type="text" name="totTime" id="totTime" placeholder="TBD" readonly style="background-color: #f8f9fa;">
        </div>
        </div>


        <h3>Customer Information</h3>
        <div class="form-grid">
          <div class="form-group full-width">
            <label for="custName">Name</label>
            <input type="text" name="custName" id="custName" placeholder="Customer name">
          </div>
          <div class="form-group full-width">
            <label for="custAddress">Address</label>
            <input type="text" name="custAddress" id="custAddress" placeholder="Address">
          </div>
          <div class="form-group">
            <label for="custPhone">Phone</label>
            <input type="tel" name="custPhone" id="custPhone" placeholder="Phone">
          </div>
          <div class="form-group">
            <label for="custEmail">Email</label>
            <input type="email" name="custEmail" id="custEmail" placeholder="Email">
          </div>
        </div>

        <h3>Concern</h3>
        <div class="form-group full-width">
          <input type="textarea" name="concern" id="concern" placeholder="Customer concern or service requested"></input>
        </div>

        <h3>Diagnosis / Cause / Correction</h3>
        <div class="form-group full-width">
          <input type="textarea" name="diagnosis" id="diagnosis" placeholder="Diagnosis and correction details"></input>
        </div>

        <h3>Recommended Repairs</h3>
        <div class="table-wrapper">
          <table id="repairs-table">
            <thead>
              <tr>
                <th>Description of Work</th>
                <th>Qty</th>
                <th>Parts #</th>
                <th>Part Price $</th>
                <th>Parts Total $</th>
                <th>Labor/$100hr.</th>
                <th>Labor Total $</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><input type="text" placeholder="Description"></td>
                <td><input type="number" placeholder="1" style="width:4em"></td>
                <td><input type="text" placeholder="Part #"></td>
                <td><input type="text" placeholder="0.00"></td>
                <td><input type="text" placeholder="0.00" readonly tabindex="-1"></td>
                <td><input type="text" placeholder="0.00"></td>
                <td><input type="text" placeholder="0.00" readonly tabindex="-1"></td>
              </tr>
              <tr>
                <td><input type="text" placeholder="Description"></td>
                <td><input type="number" placeholder="1" style="width:4em"></td>
                <td><input type="text" placeholder="Part #"></td>
                <td><input type="text" placeholder="0.00"></td>
                <td><input type="text" placeholder="0.00" readonly tabindex="-1"></td>
                <td><input type="text" placeholder="0.00"></td>
                <td><input type="text" placeholder="0.00" readonly tabindex="-1"></td>
              </tr>
            </tbody>
          </table>
        </div>
        <button type="button" class="btn btn-secondary add-repair-line">Add Repair Line</button>

        <h3>Totals</h3>
        <div class="form-grid">
          <div class="form-group">
            <label>Subtotal (Parts) $</label>
            <input type="text" id="subTotParts" name="subTotParts" placeholder="0.00" readonly tabindex="-1" aria-readonly="true">
          </div>
          <div class="form-group">
            <label>Subtotal (Labor) $</label>
            <input type="text" id="subTotLabor" name="subTotLabor" placeholder="0.00" readonly tabindex="-1" aria-readonly="true">
            <small style="display:block;color:var(--text-muted);margin-top:4px">(Labor not included in Total Estimate)</small>
          </div>
          <div class="form-group">
            <label>Tax $</label>
            <input type="text" id="tax" name="tax" placeholder="0.00" readonly tabindex="-1" aria-readonly="true">
          </div>
          <div class="form-group">
            <label>Total Estimate $</label>
            <input type="text" id="totEstimate" name="totEstimate" placeholder="0.00" readonly tabindex="-1" aria-readonly="true">
          </div>
        </div>

        <h3>Authorization</h3>
        <div class="auth-block">
          YORK COUNTY SCHOOL OF TECHNOLOGY TRANSPORTATION DEPARTMENT LIABILITY RELEASE<br><br>
          TERMS AND CONDITIONS: It is to be understood and agreed that all work submitted shall be subject to a minimum shop/lab charge to cover lab utilities and such expendable materials as waste cloths, cleaning materials, and all other items. This charge shall be determined by the department.
          It shall be further understood that inasmuch as all work performed by students is done under a learning situation in a public school, no form of guarantee or warranty whether of fitness for any particular purpose or merchantability, and whether express or implied, is extended by the York County School of Technology, nor can the students, the instructor, or the school authorities be held responsible for the quality of work performed by learners. It is expressly understood and agreed that none of the parties may be held liable in any manner in damages for any claims whether due to negligence, delay, or otherwise, and all such claims are hereby released.
          No work will be accepted by the shop and/or department unless the specific task is immediately related to the course outline at that point in the program, and no shop and/or department is to be given a guarantee of a definite completion date.
          I agree that all work will be removed from the premises within seven (7) days after notification that work is completed or cannot be repaired. All costs for materials must be paid to the Business Office before released.
          I hereby authorize the work to be done along with the necessary material, and hereby grant you and/or your students permission to operate the car or truck herein described on streets, highways, or elsewhere for the purpose of testing and/or inspection. An expressed mechanic’s lien is hereby acknowledged on the above car or truck to secure the amount of repairs thereto.
          In addition, you should understand that your vehicle/unit may be out service for an extended period of time. The instructor will not speculate, guess, or try to give you any idea of the amount of down time for your vehicle/unit. If you need your vehicle/unit in a certain time period, we suggest you seek a professional repair shop. To enable our students the opportunity to develop customer relation skills, you will be dealing directly with the students after the initial contact with the instructor.
          My signature indicates that I have read and agree to the foregoing terms.
          I hereby authorize the above repair work to be done along with the necessary materials. You and your employees may operate the vehicle for the purpose of testing, inspection, or delivery. 

        </div>
        <div class="form-grid" style="margin-top:1rem">
          <div class="form-group">
            <label>Date</label>
            <input type="date" name="sDate" id="sDate" placeholder="Date">
          </div>
        <div class="form-group full-width">
          <label>Customer Signature</label>
          <div class="signature-container">
            <canvas id="signatureCanvas" width="400" height="200" style="border: 1px solid var(--border); cursor: crosshair; background: white;"></canvas>
            <input type="hidden" name="signature" id="signatureData">
            <div style="margin-top: 5px;">
            <button type="button" id="clearSignature" style="background-color: brown; color: white;" class="btn btn-secondary">Clear Signature</button>
          </div>
          </div>
        </div>


        <button id="firstSub" type="submit" class="btn btn-primary save-ticket">Save Ticket</button>
      </form>
    </section>

    <!-- Vehicle Inspection Section (Accordion) -->
    <section class="section">
      <h2>Vehicle Inspection - Digital Courtesy Check</h2>
      <p class="form-group">
        <strong>Status colors:</strong>
        <span class="status-badge status-red">Red - Needs Service</span>
        <span class="status-badge status-yellow">Yellow - Monitor Soon</span>
        <span class="status-badge status-green">Green - OK</span>
      </p>

      <div class="accordion">
        <div class="accordion-item">
          <div class="accordion-header" data-accordion="vehicle-info">Vehicle Info</div>
          <div class="accordion-content" id="vehicle-info" style="display:block">
            <form id="ticket-form" method="POST" action="/mechanic">
              <div class="form-grid">
                <div class="form-group"><label for="year">Year</label><input id="year" type="text" placeholder="Year"></div>
                <div class="form-group"><label>Make</label><input type="text" placeholder="Make"></div>
                <div class="form-group"><label>Model</label><input type="text" placeholder="Model"></div>
                <div class="form-group"><label>Color</label><input type="text" placeholder="Color"></div>
                <div class="form-group"><label>VIN</label><input type="text" placeholder="VIN"></div>
                <div class="form-group"><label>MFG Date</label><input type="text" placeholder="MFG Date"></div>
                <div class="form-group"><label>Engine Size</label><input type="text" placeholder="Engine Size"></div>
                <div class="form-group"><label>Trans Type</label><select><option>Auto</option><option>Manual</option></select></div>
                <div class="form-group"><label>Mileage (Current)</label><input type="text" placeholder="Mileage"></div>
                <div class="form-group"><label>Mileage (Old)</label><input type="text" placeholder="Mileage"></div>
                <div class="form-group"><label>Date</label><input type="date"></div>
                <div class="form-group"><label>Plate</label><input type="text" placeholder="Plate"></div>
                <div class="form-group full-width"><label>Comments</label><input type="text" placeholder="Vehicle comments"></div>
              </div>
              <button type="button" class="section-save btn btn-secondary" data-section="vehicle-info">Save</button>
            </form>
          </div>
        </div>

        <div class="accordion-item">
          <div class="accordion-header" data-accordion="courtesy-check">Courtesy Check</div>
          <div class="accordion-content collapsed-content" id="courtesy-check">
            <div class="table-wrapper">
              <table>
                <thead>
                  <tr><th>Item</th><th>Status</th><th>Notes</th></tr>
                </thead>
                <tbody>
                  <tr><td>Wiper Blades</td><td><select><option>Red</option><option>Yellow</option><option>Green</option></select></td><td><input type="text" placeholder="Notes"></td></tr>
                  <tr><td>Headlights</td><td><select><option>Red</option><option>Yellow</option><option>Green</option></select></td><td><input type="text" placeholder="Notes"></td></tr>
                  <tr><td>Mini/Marker Lights</td><td><select><option>Red</option><option>Yellow</option><option>Green</option></select></td><td><input type="text" placeholder="Notes"></td></tr>
                  <tr><td>Air Filter</td><td><select><option>Red</option><option>Yellow</option><option>Green</option></select></td><td><input type="text" placeholder="Notes"></td></tr>
                  <tr><td>Cabin Air Filter</td><td><select><option>Red</option><option>Yellow</option><option>Green</option></select></td><td><input type="text" placeholder="Notes"></td></tr>
                  <tr><td>PCV Valve</td><td><select><option>Red</option><option>Yellow</option><option>Green</option></select></td><td><input type="text" placeholder="Notes"></td></tr>
