<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mechanic - Auto Repair Ticket System</title>
  <script src="js/column.js"></script>
  <link rel="stylesheet" href="css/styles.css">
</head>
<body>
  <header class="site-header">
    <a href="/">Auto Repair Ticket System</a>
    <p class="tagline">Mechanic View - Create & Edit Tickets</p>
  </header>

  <main class="main-content">
    <a href="/" class="back-link">&larr; Back to Home</a>

    <!-- Repair Order Section -->
    <section class="section">
      <h2>Repair Order</h2>
      <form class="repair-order-form" id="repForm" method="POST" action="/mechanic">
        <div class="form-grid">
          <div class="form-group">
            <label for="roNum">Repair Order or Task Number #</label>
            <input type="text"name="roNum" id="roNum" placeholder="Enter RO number">
          </div>
          <div class="form-group">
            <label for="roDate">Date</label>
            <input type="date" name="roDate" id="roDate">
          </div>
          <div class="form-group">
            <label for="technician">Technician Name(s)</label>
            <input type="text" name="technician" id="technician" placeholder="Enter technician name">
          </div>
        </div>

       <h3>Time Information</h3>
        <div class="form-grid">
          <div class="form-group">
        <label for="timeIn">Time In</label>
         <select name="timeIn" id="timeIn">
          <option value="">Select time...</option>
          </select>
         </div>
         <div class="form-group">
          <label for="timeOut">Time Out</label>
         <select name="timeOut" id="timeOut">
         <option value="">Select time...</option>
          </select>
       </div>
        <div class="form-group">
        <label for="totTime">Total Time</label>
         <input type="text" name="totTime" id="totTime" placeholder="e.g. 2.5 hrs">
        </div>
        </div>


        <h3>Customer Information</h3>
        <div class="form-grid">
          <div class="form-group full-width">
            <label for="custName">Name</label>
            <input type="text" name="custName" id="custName" placeholder="Customer name">
          </div>
          <div class="form-group full-width">
            <label for="custAddress">Address</label>
            <input type="text" name="custAddress" id="custAddress" placeholder="Address">
          </div>
          <div class="form-group">
            <label for="custPhone">Phone</label>
            <input type="tel" name="custPhone" id="custPhone" placeholder="Phone">
          </div>
          <div class="form-group">
            <label for="custEmail">Email</label>
            <input type="email" name="custEmail" id="custEmail" placeholder="Email">
          </div>
        </div>

        <h3>Vehicle Information</h3>
        <div class="form-grid">
          <div class="form-group">
            <label for="vehicleymm">Year/Make/Model</label>
            <input type="text" name="vehicleymm" id="vehicleymm" placeholder="e.g. 2018 Honda Accord">
          </div>
          <div class="form-group">
            <label for="vin">VIN</label>
            <input type="text" name="vin" id="vin" placeholder="VIN">
          </div>
          <div class="form-group">
            <label for="licensePlate">License Plate</label>
            <input type="text" name="licensePlate" id="licensePlate" placeholder="License plate">
          </div>
          <div class="form-group">
            <label for="mileIn">Mileage In</label>
            <input type="text" name="mileIn" id="mileIn" placeholder="Mileage">
          </div>
          <div class="form-group">
            <label for="mileOut">Mileage Out</label>
            <input type="text" name="mileOut" id="mileOut" placeholder="Mileage">
          </div>
        </div>

        <h3>Concern</h3>
        <div class="form-group full-width">
          <input type="textarea" name="concern" id="concern" placeholder="Customer concern or service requested"></input>
        </div>

        <h3>Diagnosis / Cause / Correction</h3>
        <div class="form-group full-width">
          <input type="textarea" name="diagnosis" id="diagnosis" placeholder="Diagnosis and correction details"></input>
        </div>

        <h3>Recommended Repairs</h3>
        <div class="table-wrapper">
          <table>
            <thead>
              <tr>
                <th>Description of Work</th>
                <th>Qty</th>
                <th>Parts #</th>
                <th>Part Price $</th>
                <th>Parts Total $</th>
                <th>Labor/$100hr.</th>
                <th>Labor Total $</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><input type="text" placeholder="Description"></td>
                <td><input type="number" placeholder="1" style="width:4em"></td>
                <td><input type="text" placeholder="Part #"></td>
                <td><input type="text" placeholder="0.00"></td>
                <td><input type="text" placeholder="0.00"></td>
                <td><input type="text" placeholder="0.00"></td>
                <td><input type="text" placeholder="0.00"></td>
              </tr>
              <tr>
                <td><input type="text" placeholder="Description"></td>
                <td><input type="number" placeholder="1" style="width:4em"></td>
                <td><input type="text" placeholder="Part #"></td>
                <td><input type="text" placeholder="0.00"></td>
                <td><input type="text" placeholder="0.00"></td>
                <td><input type="text" placeholder="0.00"></td>
                <td><input type="text" placeholder="0.00"></td>
              </tr>
            </tbody>
          </table>
        </div>
        <button type="button" class="btn btn-secondary add-repair-line">Add Repair Line</button>

        <h3>Totals</h3>
        <div class="form-grid">
          <div class="form-group">
            <label>Subtotal (Parts) $</label>
            <input type="text" id="subTotParts" name="subTotParts" placeholder="0.00">
          </div>
          <div class="form-group">
            <label>Subtotal (Labor) $</label>
            <input type="text" id="subTotLabor" name="subTotLabor" placeholder="0.00">
          </div>
          <div class="form-group">
            <label>Tax $</label>
            <input type="text" id="tax" name="tax" placeholder="0.00">
          </div>
          <div class="form-group">
            <label>Total Estimate $</label>
            <input type="text" id="totEstimate" name="totEstimate" placeholder="0.00">
          </div>
        </div>

        <h3>Authorization</h3>
        <div class="auth-block">
          YORK COUNTY SCHOOL OF TECHNOLOGY TRANSPORTATION DEPARTMENT LIABILITY RELEASE<br><br>
          TERMS AND CONDITIONS: It is to be understood and agreed that all work submitted shall be subject to a minimum shop/lab charge...<br><br>
          [Full terms displayed - Customer must sign to authorize]
        </div>
        <div class="form-grid" style="margin-top:1rem">
          <div class="form-group">
            <label>Date</label>
            <input type="date" name="sDate" id="sDate" placeholder="Date">
          </div>
          <div class="form-group full-width">
            <label>Customer Signature</label>
            <input type="text" name="signature" id="signature" placeholder="Signature on file needs replacement with canvas thing">
          </div>
        </div>

        <button id="firstSub" type="submit" class="btn btn-primary save-ticket">Save Ticket</button>
      </form>
    </section>

    <!-- Vehicle Inspection Section (Accordion) -->
    <section class="section">
      <h2>Vehicle Inspection - Digital Courtesy Check</h2>
      <p class="form-group">
        <strong>Status colors:</strong>
        <span class="status-badge status-red">Red - Needs Service</span>
        <span class="status-badge status-yellow">Yellow - Monitor Soon</span>
        <span class="status-badge status-green">Green - OK</span>
      </p>

      <div class="accordion">
        <div class="accordion-item">
          <div class="accordion-header" data-accordion="vehicle-info">Vehicle Info</div>
          <div class="accordion-content" id="vehicle-info" style="display:block">
            <form id="ticket-form" method="POST" action="/mechanic">
              <div class="form-grid">
                <div class="form-group"><label>Make</label><input type="text" placeholder="Make"></div>
                <div class="form-group"><label>Model</label><input type="text" placeholder="Model"></div>
                <div class="form-group"><label>Color</label><input type="text" placeholder="Color"></div>
                <div class="form-group"><label>VIN</label><input type="text" placeholder="VIN"></div>
                <div class="form-group"><label>MFG Date</label><input type="text" placeholder="MFG Date"></div>
                <div class="form-group"><label>Engine Size</label><input type="text" placeholder="Engine Size"></div>
                <div class="form-group"><label>Trans Type</label><select><option>Auto</option><option>Manual</option></select></div>
                <div class="form-group"><label>Mileage (Current)</label><input type="text" placeholder="Mileage"></div>
                <div class="form-group"><label>Mileage (Old)</label><input type="text" placeholder="Mileage"></div>
                <div class="form-group"><label>Technician</label><input type="text" placeholder="Technician"></div>
                <div class="form-group"><label>Date</label><input type="date"></div>
                <div class="form-group"><label>Plate</label><input type="text" placeholder="Plate"></div>
                <div class="form-group"><label for="year">Year</label><input id="year" type="text" placeholder="Year"></div>
                <div class="form-group full-width"><label>Comments</label><input type="text" placeholder="Vehicle comments"></div>
              </div>
              <button type="submit">Submit</button>
            </form>
          </div>
        </div>

        <div class="accordion-item">
          <div class="accordion-header" data-accordion="courtesy-check">Courtesy Check</div>
          <div class="accordion-content collapsed-content" id="courtesy-check">
            <div class="table-wrapper">
              <table>
                <thead>
                  <tr><th>Item</th><th>Status</th><th>Notes</th></tr>
                </thead>
                <tbody>
                  <tr><td>Wiper Blades</td><td><select><option>Red</option><option>Yellow</option><option>Green</option></select></td><td><input type="text" placeholder="Notes"></td></tr>
                  <tr><td>Headlights</td><td><select><option>Red</option><option>Yellow</option><option>Green</option></select></td><td><input type="text" placeholder="Notes"></td></tr>
                  <tr><td>Mini/Marker Lights</td><td><select><option>Red</option><option>Yellow</option><option>Green</option></select></td><td><input type="text" placeholder="Notes"></td></tr>
                  <tr><td>Air Filter</td><td><select><option>Red</option><option>Yellow</option><option>Green</option></select></td><td><input type="text" placeholder="Notes"></td></tr>
                  <tr><td>Cabin Air Filter</td><td><select><option>Red</option><option>Yellow</option><option>Green</option></select></td><td><input type="text" placeholder="Notes"></td></tr>
                  <tr><td>PCV Valve</td><td><select><option>Red</option><option>Yellow</option><option>Green</option></select></td><td><input type="text" placeholder="Notes"></td></tr>
                  <tr><td>Fuel Filter</td><td><select><option>Red</option><option>Yellow</option><option>Green</option></select></td><td><input type="text" placeholder="Notes"></td></tr>
                  <tr><td>Drive Belts</td><td><select><option>Red</option><option>Yellow</option><option>Green</option></select></td><td><input type="text" placeholder="Notes"></td></tr>
                  <tr><td>Hoses</td><td><select><option>Red</option><option>Yellow</option><option>Green</option></select></td><td><input type="text" placeholder="Notes"></td></tr>
                  <tr><td>Battery</td><td><select><option>Red</option><option>Yellow</option><option>Green</option></select></td><td><input type="text" placeholder="Notes"></td></tr>
                  <tr><td>Washer Fluid</td><td><select><option>Red</option><option>Yellow</option><option>Green</option></select></td><td><input type="text" placeholder="Notes"></td></tr>
                  <tr><td>Engine Oil Level</td><td><select><option>Red</option><option>Yellow</option><option>Green</option></select></td><td><input type="text" placeholder="Notes"></td></tr>
                  <tr><td>Coolant Level</td><td><select><option>Red</option><option>Yellow</option><option>Green</option></select></td><td><input type="text" placeholder="Notes"></td></tr>
                  <tr><td>Brake Fluid</td><td><select><option>Red</option><option>Yellow</option><option>Green</option></select></td><td><input type="text" placeholder="Notes"></td></tr>
                  <tr><td>Brake Lights</td><td><select><option>Red</option><option>Yellow</option><option>Green</option></select></td><td><input type="text" placeholder="Notes"></td></tr>
                  <tr><td>Turn Signals</td><td><select><option>Red</option><option>Yellow</option><option>Green</option></select></td><td><input type="text" placeholder="Notes"></td></tr>
                  </tbody>
              </table>
            </div>

            <div class="form-group full-width"><label>Comments</label><input type="text" placeholder="Comments"></div>

          </div>
        </div>

        <div class="accordion-item">
          <div class="accordion-header" data-accordion="tires">Tires</div>
          <div class="accordion-content collapsed-content" id="tires">
            <div class="form-grid">
              <div class="form-group"><label>Size</label><input type="text" placeholder="Size"></div>
              <div class="form-group"><label>Speed Rating</label><input type="text" placeholder="Speed Rating"></div>
              <div class="form-group"><label>LF</label><input type="text" placeholder="Tread"></div>
              <div class="form-group"><label>RF</label><input type="text" placeholder="Tread"></div>
              <div class="form-group"><label>LR</label><input type="text" placeholder="Tread"></div>
              <div class="form-group"><label>RR</label><input type="text" placeholder="Tread"></div>
              <div class="form-group"><label>SP</label><input type="text" placeholder="Spare"></div>
              <div class="form-group"><label>Tread Depth (32nds)</label><input type="text" placeholder="Depth"></div>
              <div class="form-group"><label>Rotation Due?</label><select><option>Yes</option><option>No</option><option>N/A</option></select></div>
              <div class="form-group"><label>Balance?</label><select><option>Yes</option><option>No</option><option>N/A</option></select></div>
              <div class="form-group"><label>Alignment Check?</label><select><option>Yes</option><option>No</option><option>N/A</option></select></div>
              <div class="form-group full-width"><label>Comments</label><input type="text" placeholder="Tire comments"></div>
            </div>
          </div>
        </div>

        <div class="accordion-item">
          <div class="accordion-header" data-accordion="steering">Steering & Suspension / Driveline</div>
          <div class="accordion-content collapsed-content" id="steering">
            <div class="table-wrapper">
              <table>
                <thead>
                  <tr><th>Item</th><th>Left</th><th>Right</th><th>Front</th><th>Rear</th></tr>
                </thead>
                <tbody>
                  <tr><td>Ball Joints (Upper)</td><td><select><option>OK</option><option>Monitor</option><option>Replace</option></select></td><td><select><option>OK</option><option>Monitor</option><option>Replace</option></select></td><td>-</td><td>-</td></tr>
                  <tr><td>Ball Joints (Lower)</td><td><select><option>OK</option><option>Monitor</option><option>Replace</option></select></td><td><select><option>OK</option><option>Monitor</option><option>Replace</option></select></td><td>-</td><td>-</td></tr>
                  <tr><td>Tie Rod Ends (Inner)</td><td><select><option>OK</option><option>Monitor</option><option>Replace</option></select></td><td><select><option>OK</option><option>Monitor</option><option>Replace</option></select></td><td>-</td><td>-</td></tr>
                  <tr><td>Tie Rod Ends (Outer)</td><td><select><option>OK</option><option>Monitor</option><option>Replace</option></select></td><td><select><option>OK</option><option>Monitor</option><option>Replace</option></select></td><td>-</td><td>-</td></tr>
                  <tr><td>CV Boots</td><td><select><option>OK</option><option>Monitor</option><option>Replace</option></select></td><td><select><option>OK</option><option>Monitor</option><option>Replace</option></select></td><td>-</td><td>-</td></tr>
                  <tr><td>Struts</td><td><select><option>OK</option><option>Monitor</option><option>Replace</option></select></td><td><select><option>OK</option><option>Monitor</option><option>Replace</option></select></td><td>-</td><td>-</td></tr>
                </tbody>
              </table>
            </div>

            <div class="form-group full-width"><label>Comments</label><input type="text" placeholder="Steering & Suspension comments"></div>

          </div>
        </div>

        <div class="accordion-item">
          <div class="accordion-header" data-accordion="brakes">Brakes (Visual Inspection)</div>
          <div class="accordion-content collapsed-content" id="brakes">
            <div class="table-wrapper">
              <table>
                <thead>
                  <tr><th></th><th>Spec</th><th>Actual</th></tr>
                </thead>
                <tbody>
                  
                  <tr><td>Pads/Shoes FL</td><td><input type="text" placeholder="Spec"></td><td><input type="text" placeholder="Actual"></td></tr>
                  <tr><td>Pads/Shoes FR</td><td><input type="text" placeholder="Spec"></td><td><input type="text" placeholder="Actual"></td></tr>
                  <tr><td>Pads/Shoes RL</td><td><input type="text" placeholder="Spec"></td><td><input type="text" placeholder="Actual"></td></tr>
                  <tr><td>Pads/Shoes RR</td><td><input type="text" placeholder="Spec"></td><td><input type="text" placeholder="Actual"></td></tr>

                  <tr><td>Rotor/Drum FL (Thickness/Max Dia.)</td><td><input type="text" placeholder="Spec"></td><td><input type="text" placeholder="Actual"></td></tr>
                  <tr><td>Rotor/Drum FR (Thickness/Max Dia.)</td><td><input type="text" placeholder="Spec"></td><td><input type="text" placeholder="Actual"></td></tr>
                  <tr><td>Rotor/Drum RL (Thickness/Max Dia.)</td><td><input type="text" placeholder="Spec"></td><td><input type="text" placeholder="Actual"></td></tr>
                  <tr><td>Rotor/Drum RR (Thickness/Max Dia.)</td><td><input type="text" placeholder="Spec"></td><td><input type="text" placeholder="Actual"></td></tr>

                  <tr><td>Wheel Bearings FL</td><td><select><option>OK</option><option>Replace</option></select></td><td>-</td></tr>
                  <tr><td>Wheel Bearings FR</td><td><select><option>OK</option><option>Replace</option></select></td><td>-</td></tr>
                  <tr><td>Wheel Bearings RL</td><td><select><option>OK</option><option>Replace</option></select></td><td>-</td></tr>
                  <tr><td>Wheel Bearings RR</td><td><select><option>OK</option><option>Replace</option></select></td><td>-</td></tr>

                </tbody>
              </table>
            </div>

            <div class="form-group full-width"><label>Comments</label><input type="text" placeholder="Brake Comments"></div>

          </div>
        </div>

        <div class="accordion-item">
          <div class="accordion-header" data-accordion="emissions">Emissions / Electrical Lighting</div>
          <div class="accordion-content collapsed-content" id="emissions">
            <div class="form-grid">
              <div class="form-group"><label>OBD/Emissions (Pass/Fail)</label><select><option>Pass</option><option>Fail</option><option>N/A</option></select></div>
              <div class="form-group"><label>State Inspection Due (M/Y)</label><input type="text" placeholder="e.g. 03/2025"></div>
              <div class="form-group"><label>Emission Due (M/Y)</label><input type="text" placeholder="e.g. 03/2025"></div>
              <div class="form-group"><label>Next Oil Change Mileage</label><input type="text" placeholder="Mileage"></div>
              <div class="form-group"><label>Inspected By</label><input type="text" placeholder="Name"></div>
              <div class="form-group"><label>Re-Inspected By</label><input type="text" placeholder="Name"></div>
              <!-- Tags input inserted by assistant: placed above Comments -->
              <div class="form-group full-width">
                <label>Warnings</label>
                <div id="tags-root">
                  <div id="tag-list" style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:6px"></div>
                  <div style="display:flex;gap:6px">
                    <input id="tag-input" type="text" placeholder="Add a warning (e.g. Check Engine Light)" style="flex:1;padding:0.5rem;border-radius:8px;border:1px solid rgba(0,0,0,0.08)">
                    <button id="add-tag" type="button" class="btn">Add</button>
                  </div>
                </div>
                <input type="hidden" name="tags" id="tags-hidden" value="">
              </div>

              <!-- Comments field placed below Tags -->
              <div class="form-group full-width">
                <label>Comments</label>
                <textarea name="emissionsComments" id="emissions-comments" placeholder="Additional notes or comments"></textarea>
              </div>
              
            </div>
            <div class="form-group full-width"><label>Comments</label><input type="text" placeholder="Emissions / Electrical Lighting comments"></div>
          </div>
        </div>

      </div>
    </section>

    <!-- Video Upload Section -->
    <section class="section">
      <h2>Upload Video</h2>
      <div class="video-upload-zone" id="video-upload-zone">
        <p>Drop video here or click to upload</p>
        <input type="file" id="video-file" accept="video/*" style="display:none">
        <button type="button" class="btn btn-secondary" id="upload-trigger">Choose File</button>
      </div>
      <button type="button" class="btn btn-primary" id="upload-btn" style="margin-top:1rem">Upload</button>
    </section>
  </main>

  <script src="js/mockup.js"></script>
  <script src="js/form.js"></script>
  <script>
    document.getElementById('repForm').addEventListener('submit', function() {
      event.preventDefault();
    let roNum = document.getElementById('roNum').value;
    let technician = document.getElementById('technician').value;
    let custName = document.getElementById('custName').value;
    let vehicleymm= document.getElementById('vehicleymm').value;
    let vin = document.getElementById('vin').value;
    let licensePlate = document.getElementById('licensePlate').value;
    let mileIn = document.getElementById('mileIn').value;
    let mileOut = document.getElementById('mileOut').value;
    let concern = document.getElementById('concern').value;
    let diagnosis = document.getElementById('diagnosis').value;
    let tax = document.getElementById('tax').value;
    let totEstimate = document.getElementById('totEstimate').value;
    let custAddress = document.getElementById('custAddress').value;
    let custPhone = document.getElementById('custPhone').value;
    let custEmail = document.getElementById('custEmail').value;
    // Validation logic
    let errors = [];
    
   
    
    technician = technician.trim();
    custName = custName.trim();
    vehicleymm = vehicleymm.trim();
    mileIn = parseInt(mileIn);
    mileOut = parseInt(mileOut);
    vin = vin.trim();
    licensePlate = licensePlate.trim();
    tax = parseFloat(tax);
    totEstimate = parseFloat(totEstimate);
    custAddress = custAddress.trim();
    let timeIn = document.getElementById('timeIn').value;
    let timeOut = document.getElementById('timeOut').value;
    roNum = Number(roNum.trim());
    if (isNaN(roNum)) {
    errors.push('Repair Order number must be a valid number.');
    }

    if (licensePlate.length > 10) {
    errors.push('License plate Number too long. Max 10 characters.');
    }
    if (vin.length > 17) {
    errors.push('VIN too long. Max 17 characters.');
    }
    if (custName === '') {
    errors.push('Customer name cannot be empty.');
    }
    if (vehicleymm === '') {
    errors.push('Vehicle Year/Make/Model cannot be empty.');
    }
    if (isNaN(mileIn) || isNaN(mileOut)) {
    errors.push('Mileage In and Out must be valid numbers.');
    }
    if (mileIn < 0 || mileOut < 0) {
    errors.push('Mileage cannot be negative.');
    }
    if (mileOut < mileIn) {
    errors.push('Mileage Out cannot be less than Mileage In.');
    }
    if (concern === '') {
    errors.push('Customer concern cannot be empty.Put all good or no concern if no concern.');
    }
    if (diagnosis === '') {
    errors.push('Diagnosis cannot be empty. Put N/A if no diagnosis.');
    }
    if (isNaN(tax)) {
    errors.push('Tax must be a valid number.');
    }
    if (tax < 0) {
    errors.push('Tax cannot be negative.');
    }
    if (isNaN(totEstimate)) {
    errors.push('Total Estimate must be a valid number.');
    }
    if (totEstimate < 0) {
    errors.push('Total Estimate cannot be negative.');
    }
    if (custEmail !== '' && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(custEmail)) {
    errors.push('Email must be in a valid format.');
    }
    if (technician === '') {
    errors.push('Technician name cannot be empty.');
    }
    if (technician.length < 2) {
    errors.push('Technician name must be at least 2 characters.');
    }
    if (!/^[a-zA-Z\s\-\.]+$/.test(technician)) {
    errors.push('Technician name can only contain letters, spaces, hyphens, and periods.');
    }
   if (custPhone !== '' && !/^(\d{10}|\d{3}-\d{3}-\d{4})$/.test(custPhone)) {
    errors.push('Phone number must be 10 digits or XXX-XXX-XXXX format.');
}
if (custAddress === '') {
    errors.push('Customer address cannot be empty.');
}
if (custAddress.length < 5) {
    errors.push('Customer address must be at least 5 characters.');
}
if (custAddress.length > 100) {
    errors.push('Customer address cannot exceed 100 characters.');
}

if (timeIn === '') {
    errors.push('Time In must be selected.');
}
if (timeOut === '') {
    errors.push('Time Out must be selected.');
}

    if (errors.length > 0) {
        console.log('Errors found:', errors);
         alert(errors.join('\n'));
    } else {
        console.log('Form is valid! Submitting to backend...');
        document.getElementById('repForm').submit();
    }
    });
        function populateTimeDropdowns() {
        let timeInSelect = document.getElementById('timeIn');
        let timeOutSelect = document.getElementById('timeOut');
    
   
       for (let hour = 1; hour <= 12; hour++) {
           for (let minute = 0; minute < 60; minute += 30) {
            let timeString = `${hour}:${minute.toString().padStart(2, '0')}`;
            
            // AM times
            let amOption1 = new Option(`${timeString} AM`, `${timeString} AM`);
            let amOption2 = new Option(`${timeString} AM`, `${timeString} AM`);
            timeInSelect.add(amOption1);
            timeOutSelect.add(amOption2);
            
            // PM times
            let pmOption1 = new Option(`${timeString} PM`, `${timeString} PM`);
            let pmOption2 = new Option(`${timeString} PM`, `${timeString} PM`);
            timeInSelect.add(pmOption1);
            timeOutSelect.add(pmOption2);
            }
        }
    }


    populateTimeDropdowns();

  </script>
