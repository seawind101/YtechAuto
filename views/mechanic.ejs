                </tbody>
              </table>
            </div>

            <div class="form-group full-width"><label>Comments</label><input type="text" placeholder="Steering & Suspension comments"></div>

            <button type="button" class="section-save btn btn-secondary" data-section="steering" style="margin-top:8px">Save</button>
          </div>
        </div>

        <div class="accordion-item">
          <div class="accordion-header" data-accordion="brakes">Brakes (Visual Inspection)</div>
          <div class="accordion-content collapsed-content" id="brakes">
            <div class="table-wrapper">
              <table>
                <thead>
                  <tr><th></th><th>Spec</th><th>Actual</th></tr>
                </thead>
                <tbody>
                  
                  <tr><td>Pads/Shoes FL</td><td><input type="text" placeholder="Spec"></td><td><input type="text" placeholder="Actual"></td></tr>
                  <tr><td>Pads/Shoes FR</td><td><input type="text" placeholder="Spec"></td><td><input type="text" placeholder="Actual"></td></tr>
                  <tr><td>Pads/Shoes RL</td><td><input type="text" placeholder="Spec"></td><td><input type="text" placeholder="Actual"></td></tr>
                  <tr><td>Pads/Shoes RR</td><td><input type="text" placeholder="Spec"></td><td><input type="text" placeholder="Actual"></td></tr>

                  <tr><td>Rotor/Drum FL (Thickness/Max Dia.)</td><td><input type="text" placeholder="Spec"></td><td><input type="text" placeholder="Actual"></td></tr>
                  <tr><td>Rotor/Drum FR (Thickness/Max Dia.)</td><td><input type="text" placeholder="Spec"></td><td><input type="text" placeholder="Actual"></td></tr>
                  <tr><td>Rotor/Drum RL (Thickness/Max Dia.)</td><td><input type="text" placeholder="Spec"></td><td><input type="text" placeholder="Actual"></td></tr>
                  <tr><td>Rotor/Drum RR (Thickness/Max Dia.)</td><td><input type="text" placeholder="Spec"></td><td><input type="text" placeholder="Actual"></td></tr>

                  <tr><td>Wheel Bearings FL</td><td><select><option>OK</option><option>Replace</option></select></td><td>-</td></tr>
                  <tr><td>Wheel Bearings FR</td><td><select><option>OK</option><option>Replace</option></select></td><td>-</td></tr>
                  <tr><td>Wheel Bearings RL</td><td><select><option>OK</option><option>Replace</option></select></td><td>-</td></tr>
                  <tr><td>Wheel Bearings RR</td><td><select><option>OK</option><option>Replace</option></select></td><td>-</td></tr>

                </tbody>
              </table>
            </div>

            <div class="form-group full-width"><label>Comments</label><input type="text" placeholder="Brake Comments"></div>

            <button type="button" class="section-save btn btn-secondary" data-section="brakes" style="margin-top:8px">Save</button>

          </div>
        </div>

        <div class="accordion-item">
          <div class="accordion-header" data-accordion="emissions">Emissions / Electrical Lighting</div>
          <div class="accordion-content collapsed-content" id="emissions">
            <div class="table-wrapper">
              <table>
                <thead>
                <tr><th>Item</th><th>Status</th><th>Notes</th></tr>
              </thead>
              <tbody>
                <tr><td>Converter</td><td><select><option>Red</option><option>Yellow</option><option>Green</option></select></td><td><input type="text" placeholder="Notes"></td></tr>
                <tr><td>Clamps</td><td><select><option>Red</option><option>Yellow</option><option>Green</option></select></td><td><input type="text" placeholder="Notes"></td></tr>
                <tr><td>Hangers</td><td><select><option>Red</option><option>Yellow</option><option>Green</option></select></td><td><input type="text" placeholder="Notes"></td></tr>
                <tr><td>Leaks</td><td><select><option>Red</option><option>Yellow</option><option>Green</option></select></td><td><input type="text" placeholder="Notes"></td></tr>
                </tbody>
              </table>
            </div>

            <div class="form-grid">
              <div class="form-group"><label>OBD/Emissions (Pass/Fail)</label><select><option>Pass</option><option>Fail</option><option>N/A</option></select></div>
              <div class="form-group"><label>State Inspection Due (M/Y)</label><input type="text" placeholder="e.g. 03/2025"></div>
              <div class="form-group"><label>Emission Due (M/Y)</label><input type="text" placeholder="e.g. 03/2025"></div>
              <div class="form-group"><label>Next Oil Change Mileage</label><input type="text" placeholder="Mileage"></div>
              <div class="form-group"><label>Inspected By</label><input type="text" placeholder="Name"></div>
              <div class="form-group"><label>Re-Inspected By</label><input type="text" placeholder="Name"></div>
              <!-- Tags input inserted by assistant: placed above Comments -->
              <div class="form-group full-width">
                <label>Warnings</label>
                <div id="tags-root">
                  <div id="tag-list" style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:6px"></div>
                  <div style="display:flex;gap:6px">
                    <input id="tag-input" type="text" placeholder="Add a warning (e.g. Check Engine Light)" style="flex:1;padding:0.5rem;border-radius:8px;border:1px solid rgba(0,0,0,0.08)">
                    <button id="add-tag" type="button" class="btn">Add</button>
                  </div>
                </div>
                <input type="hidden" name="tags" id="tags-hidden" value="">
              </div>

              <!-- Comments field placed below Tags -->
              <div class="form-group full-width">
                <label>Comments</label>
                <textarea name="emissionsComments" id="emissions-comments" placeholder="Additional notes or comments"></textarea>
              </div>
              
            </div>
            <div class="form-group full-width"><label>Comments</label><input type="text" placeholder="Emissions / Electrical Lighting comments"></div>
            <button type="button" class="section-save btn btn-secondary" data-section="emissions" style="margin-top:8px">Save</button>
          </div>
        </div>

      </div>
    </section>

    <!-- Video Upload Section -->
    <section class="section">
      <h2>Upload Video</h2>
      <div class="video-upload-zone" id="video-upload-zone">
        <p>Drop video here or click to upload</p>
        <input type="file" id="video-file" accept="video/*" style="display:none">
        <button type="button" class="btn btn-secondary" id="upload-trigger">Choose File</button>
      </div>
      <button type="button" class="btn btn-primary" id="upload-btn" style="margin-top:1rem">Upload</button>
    </section>

    <!-- Picture Upload Section -->
    <section class="section">
      <h2>Upload Picture</h2>
      <div class="picture-upload-zone" id="picture-upload-zone">
        <p>Drop picture here or click to upload</p>
        <input type="file" id="picture-file" accept="image/*" style="display:none">
        <button type="button" class="btn btn-secondary" id="upload-trigger">Choose File</button>
      </div>
      <button type="button" class="btn btn-primary" id="upload-btn" style="margin-top:1rem">Upload</button>
    </section>
  </main>
</body>
</html>
