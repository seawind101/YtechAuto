<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EditBench</title>
          <link rel="stylesheet" href="/css/mechanicEdit.css">
          <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <header class="site-header">
        <h1>Edit Tickets</h1>
        <p class="tagline">Search and modify your existing repair tickets post-haste</p>
        <a href="/mechanicDis" class="back-link">&larr; Back</a>
    </header>

    <main class="main-content">
        <div class="section">
            <h2>Select an Incomplete Ticket</h2>
            <div class="form-group" style="display:flex;gap:8px;align-items:center;">
                <label for="ticket-select" style="min-width:140px;margin:0">Ticket</label>
                <select id="ticket-select" style="flex:1;padding:6px;border:1px solid #ccc;border-radius:4px;"><option value="">-- Select ticket --</option></select>
                <button id="load-ticket" class="btn btn-primary" disabled style="margin-left:8px;">Open</button>
            </div>
            <p style="margin-top:8px;color:#555;font-size:0.95rem">Selecting a ticket will open the mechanic editor page with that ticket pre-filled.</p>
            <script>
                (function(){
                    function $q(sel){ return document.querySelector(sel); }
                    var select = $q('#ticket-select');
                    var btn = $q('#load-ticket');

                    function fetchTickets(){
                        fetch('/mechanic/incomplete').then(function(r){ return r.json(); }).then(function(list){
                            select.innerHTML = '<option value="">-- Select ticket --</option>';
                            list.forEach(function(t){
                                var opt = document.createElement('option');
                                opt.value = t.id;
                                var label = (t.id || '') + ' — ' + (t.customerName || '(no name)') + ' — ' + (t.date || '');
                                opt.textContent = label;
                                select.appendChild(opt);
                            });
                        }).catch(function(err){
                            console.error('Failed to load tickets', err);
                        });
                    }

                    select.addEventListener('change', function(){
                        btn.disabled = !select.value;
                        // auto-redirect when selected
                        if (select.value) {
                            window.location.href = '/mechanic?id=' + select.value;
                        }
                    });

                    btn.addEventListener('click', function(){
                        if (!select.value) return;
                        window.location.href = '/mechanic?id=' + select.value;
                    });

                    // init
                    fetchTickets();
                })();
            </script>
        </div>
    </main>
</body>
</html>
